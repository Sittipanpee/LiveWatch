{
  "manifest_version": 3,
  "name": "LiveWatch — Live Shop Monitor",
  "version": "1.0.0",
  "description": "AI-powered monitor for live shop sellers. Analyzes presenter behavior during live streams and sends real-time LINE alerts. Supports popular live commerce platforms.",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "activeTab",
    "scripting",
    "identity"
  ],
  "host_permissions": [
    "https://shop.tiktok.com/*",
    "https://text.pollinations.ai/*",
    "https://gen.pollinations.ai/*",
    "https://api.line.me/*",
    "https://*.supabase.co/*",
    "https://sheets.googleapis.com/*",
    "https://www.googleapis.com/*",
    "https://accounts.google.com/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://shop.tiktok.com/streamer/live/*"
      ],
      "js": [
        "src/injected.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://shop.tiktok.com/streamer/live/*"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "settings/settings.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "oauth2": {
    "client_id": "437889543814-7n8n7t80f83rfl5kmjacae7v68hr42i2.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/spreadsheets",
      "https://www.googleapis.com/auth/drive.file"
    ]
  }
}